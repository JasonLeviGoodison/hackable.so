{
  "name": "@hackable/api",
  "version": "1.0.0",
  "description": "hackable API - intentionally vulnerable lab backend",
  "license": "Apache-2.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "serve": "node dist/index.js",
    "start": "node dist/migrate.js && npm run serve",
    "db:setup": "ts-node scripts/db.ts setup",
    "db:migrate": "ts-node scripts/db.ts migrate",
    "db:seed": "ts-node scripts/db.ts seed",
    "db:users": "ts-node scripts/db.ts users"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
