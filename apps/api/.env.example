# Copy this file to apps/api/.env before running the API.
# Use a throwaway Supabase project and throwaway credentials only.

PORT=4000
NODE_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me
DATABASE_URL=postgresql://postgres:postgres@db.your-project.supabase.co:5432/postgres

# Set this explicitly. If you want to preserve the weak-JWT challenge, use a
# throwaway weak value such as "secret123" in your local lab only.
JWT_SECRET=replace-with-a-throwaway-demo-secret

INTERNAL_API_TOKEN=hackable-internal-demo-token

# Release guard: this app is intentionally vulnerable and must not be started
# unless you explicitly acknowledge the deployment model.
ACKNOWLEDGE_INTENTIONALLY_VULNERABLE_APP=yes
HACKABLE_DEPLOYMENT_MODE=single-tenant
